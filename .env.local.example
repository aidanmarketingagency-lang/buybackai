# Copy this file to .env.local and fill in the values for local development.
# .env.local is gitignored — never commit real secrets.

# ── Supabase (required) ────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Anthropic (required) ───────────────────────────────────────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── Google OAuth (required for Gmail + Calendar agents) ────────────────────
# https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <APP_URL>/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── App URL ────────────────────────────────────────────────────────────────
# In dev: http://localhost:3000
# In prod: https://buybackai.vercel.app (or your custom domain)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Cron secret (required) ─────────────────────────────────────────────────
# Any random string. Vercel Cron sends this in the Authorization header.
# Generate with:  openssl rand -hex 32
CRON_SECRET=

# ── Stripe (optional — billing routes return 503 without these) ────────────
# See docs/SETUP-BILLING.md
STRIPE_SECRET_KEY=
STRIPE_PRICE_PRO=
STRIPE_PRICE_FOUNDER=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── Resend (optional — emails are skipped without these) ───────────────────
# See docs/SETUP-EMAIL.md
RESEND_API_KEY=
RESEND_FROM_EMAIL=BuybackAI <onboarding@resend.dev>
RESEND_REPLY_TO=
EMAIL_UNSUB_SECRET=
